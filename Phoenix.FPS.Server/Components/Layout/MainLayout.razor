@inherits LayoutComponentBase

<div class="dashboard-layout">
    <header class="dashboard-header">
        <div class="container-fluid px-4">
            <div class="d-flex align-items-center justify-content-between py-3">
                <div class="d-flex align-items-center gap-3">
                    <div class="header-icon">
                        <img src="logo.png" alt="Phoenix" width="28" height="28" style="image-rendering:pixelated" />
                    </div>
                    <div>
                        <h1 class="h5 mb-0 fw-semibold">Phoenix FPS Server</h1>
                        <span class="text-secondary small">Dashboard</span>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <span class="badge bg-accent-subtle text-accent px-3 py-2 rounded-pill">
                        v@(Server.CFG.Version)
                    </span>
                </div>
            </div>
        </div>
    </header>
    <main class="dashboard-main">
        @Body
    </main>
</div>
